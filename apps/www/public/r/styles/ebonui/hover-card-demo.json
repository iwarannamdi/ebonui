{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "hover-card-demo",
  "title": "Hover Card Demo",
  "description": "Example showing a hover card component.",
  "registryDependencies": [
    "@ebonui/ui/hover-card"
  ],
  "files": [
    {
      "path": "registry/ebonui/examples/hover-card-demo.tsx",
      "content": "\"use client\"\n\nimport {\n  HoverCard,\n  HoverCardContent,\n  HoverCardTrigger,\n} from \"@/registry/ebonui/ui/hover-card\"\n\ninterface HoverCardDemoProps {\n  side?: \"top\" | \"bottom\" | \"left\" | \"right\"\n  sideOffset?: number\n  align?: \"start\" | \"center\" | \"end\"\n  alignOffset?: number\n  followCursor?: boolean | \"x\" | \"y\"\n}\n\nexport function HoverCardDemo({\n  side,\n  sideOffset = 8,\n  align = \"center\",\n  alignOffset,\n  followCursor,\n}: HoverCardDemoProps) {\n  return (\n    <HoverCard>\n      <HoverCardTrigger asChild>\n        <a\n          href=\"https://x.com/ebonui\"\n          target=\"_blank\"\n          rel=\"noopener noreferrer\"\n          className=\"block size-14 overflow-hidden rounded-2xl shadow-sm transition-transform hover:scale-105\"\n        >\n          <img\n            src=\"https://ebonui.com/_next/image?url=%2Flogo.png&w=64&q=75\"\n            alt=\"Ebon UI\"\n            className=\"h-full w-full object-cover\"\n          />\n        </a>\n      </HoverCardTrigger>\n\n      <HoverCardContent\n        side={side}\n        sideOffset={sideOffset}\n        align={align}\n        alignOffset={alignOffset}\n        className=\"w-80 p-5\"\n      >\n        <div className=\"flex flex-col gap-5\">\n          <div className=\"flex items-center gap-4\">\n            <div className=\"size-16 overflow-hidden rounded-2xl shadow-sm\">\n              <img\n                src=\"https://ebonui.com/_next/image?url=%2Flogo.png&w=64&q=75\"\n                alt=\"Ebon UI\"\n                className=\"h-full w-full object-cover\"\n              />\n            </div>\n\n            <div>\n              <div className=\"text-lg font-semibold tracking-tight\">\n                Ebon UI\n              </div>\n              <div className=\"text-muted-foreground text-sm\">@ebonui</div>\n            </div>\n          </div>\n\n          <p className=\"text-muted-foreground text-sm leading-relaxed\">\n            Beautifully animated React components built with Tailwind CSS,\n            TypeScript, and Motion. Open source, production-ready, and designed\n            for delightful user experiences.\n          </p>\n\n          <div className=\"flex gap-8 text-sm\">\n            <div className=\"flex items-center gap-1.5\">\n              <span className=\"text-foreground font-semibold\">248</span>\n              <span className=\"text-muted-foreground\">Following</span>\n            </div>\n            <div className=\"flex items-center gap-1.5\">\n              <span className=\"text-foreground font-semibold\">12.4k</span>\n              <span className=\"text-muted-foreground\">Followers</span>\n            </div>\n          </div>\n          <a\n            href=\"https://x.com/ebonui\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            className=\"bg-foreground mt-2 inline-flex h-9 w-full items-center justify-center rounded-xl text-sm font-medium text-white transition-colors hover:bg-zinc-800 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-100\"\n          >\n            Follow on X\n          </a>\n        </div>\n      </HoverCardContent>\n    </HoverCard>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}