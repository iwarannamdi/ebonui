{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "tooltip-demo-two",
  "title": "Tooltip Demo",
  "description": "Example showing a tooltip component.",
  "registryDependencies": [
    "@ebonui/ui/tooltip"
  ],
  "files": [
    {
      "path": "registry/ebonui/examples/tooltip-demo-two.tsx",
      "content": "\"use client\"\n\nimport {\n  Tooltip,\n  TooltipContent,\n  TooltipProvider,\n  TooltipTrigger,\n} from \"@/registry/ebonui/ui/tooltip\"\n\nexport default function TooltipDemo() {\n  return (\n    <TooltipProvider>\n      <div className=\"flex min-h-[200px] items-center justify-center gap-6\">\n        <Tooltip>\n          <TooltipTrigger className=\"rounded-md border px-4 py-2\">\n            More details\n          </TooltipTrigger>\n          <TooltipContent className=\"max-w-[200px]\">\n            <div className=\"space-y-1\">\n              <p className=\"font-medium\">EbonUI Tooltip</p>\n              <p className=\"text-xs text-zinc-400\">\n                Smooth animations, glass effect, and better UX.\n              </p>\n            </div>\n          </TooltipContent>\n        </Tooltip>\n      </div>\n    </TooltipProvider>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}